{
  "expo": {
    "name": "numblitz",
    "slug": "numblitz",
    "scheme": "numblitz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shanthatos.numblitz",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "exp.direct": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/katex/Katex.ttf",
            "./assets/fonts/katex/Katex_italic.ttf",
            "./assets/fonts/katex/Katex_bold.ttf",
            "./assets/fonts/katex/Katex_bold_italic.ttf",
            "./assets/fonts/mulish/Mulish.ttf",
            "./assets/fonts/mulish/Mulish_italic.ttf",
            "./assets/fonts/mulish/Mulish_bold.ttf",
            "./assets/fonts/mulish/Mulish_bold_italic.ttf",
            "./assets/fonts/nunito/Nunito.ttf",
            "./assets/fonts/nunito/Nunito_italic.ttf",
            "./assets/fonts/nunito/Nunito_bold.ttf",
            "./assets/fonts/nunito/Nunito_bold_italic.ttf"
          ]
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2cf7091b-2b81-4049-8b16-92d24861a669"
      }
    }
  }
}